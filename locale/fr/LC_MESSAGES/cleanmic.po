msgstr "Khip (non installé)"

msgid "Not detected — copy libkhip.so to ~/.local/lib/"
msgstr "Non détecté — copiez libkhip.so dans ~/.local/lib/"

msgid "Noise suppression"
msgstr "Suppression du bruit"

msgid "How aggressively noise is removed"
msgstr "Agressivité de la suppression du bruit"

